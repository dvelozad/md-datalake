; NVT simulation for lysozyme

integrator      = md
dt              = 0.002
nsteps          = 500000

tcoupl          = V-rescale
tc-grps         = System
tau_t           = 0.1
ref_t           = 300

coulombtype     = PME
rcoulomb        = 1.0
rvdw            = 1.0

constraints     = h-bonds
constraint_algorithm = lincs
