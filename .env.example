# Database Configuration
DATABASE_URL=postgresql+asyncpg://mdrepo:mdrepo_dev_password@localhost:5432/mdrepo

# Storage Backend (filesystem or s3)
STORAGE_BACKEND=filesystem
STORAGE_ROOT=/tmp/mddatalake/artifacts

# S3/MinIO Configuration (if STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=md-simulations
S3_REGION=us-east-1

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Ingestion Configuration
COMPRESS_TRAJECTORIES=true
COMPRESSION_FORMAT=gzip
CHECKSUM_ALGORITHM=sha256
